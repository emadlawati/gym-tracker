generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String            @id @default(cuid())
  name      String
  title     String?
  sessions  WorkoutSession[]
  weights   BodyWeight[]
  profile   UserProfile?
  achievements Achievement[]
  createdAt DateTime          @default(now())
}

model WorkoutTemplate {
  id        String              @id @default(cuid())
  name      String              @unique
  exercises TemplateExercise[]
  sessions  WorkoutSession[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model TemplateExercise {
  id           String          @id @default(cuid())
  templateId   String
  template     WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseName String
  sets         Int             @default(3)
  sortOrder    Int             @default(0)
  notes        String?
  settings     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model WorkoutSession {
  id           String          @id @default(cuid())
  templateId   String?
  template     WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime        @default(now())
  notes        String?
  completed    Boolean         @default(false)
  duration     Int?
  xpEarned     Int?
  xpAwarded    Boolean         @default(false)
  exerciseSets ExerciseSet[]
  createdAt    DateTime        @default(now())
}

model ExerciseSet {
  id           String         @id @default(cuid())
  sessionId    String
  session      WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseName String
  setNumber    Int
  setType      String?        @default("working")
  weight       Float          @default(0)
  reps         Int            @default(0)
  rpe          Float?
  completed    Boolean        @default(false)
  feeling      String?
  createdAt    DateTime       @default(now())
}

model BodyWeight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model ExerciseSettingsEntry {
  id           String   @id @default(cuid())
  exerciseName String   @unique
  settings     String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentXP       Int       @default(0)
  lifetimeVolume  Int       @default(0)
  totalSessions   Int       @default(0)
  totalPRs        Int       @default(0)
  currentStreak   Int       @default(0)
  bestStreak      Int       @default(0)
  lastWorkoutDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Achievement {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String
  tier       String    @default("bronze")
  unlockedAt DateTime?
  progress   Float     @default(0)
  createdAt  DateTime  @default(now())

  @@unique([userId, key])
}
